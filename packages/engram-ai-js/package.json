{
  "name": "engram-ai",
  "version": "0.1.0",
  "description": "Long-term semantic memory for AI agents (TypeScript)",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./mcp": {
      "types": "./dist/mcp/index.d.ts",
      "import": "./dist/mcp/index.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "uuid": "^11.1.0"
  },
  "peerDependencies": {
    "@neondatabase/serverless": ">=0.9.0",
    "pg": ">=8.0.0"
  },
  "peerDependenciesMeta": {
    "@neondatabase/serverless": {
      "optional": true
    },
    "pg": {
      "optional": true
    }
  },
  "devDependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "@types/node": "^22.15.3",
    "@types/pg": "^8.15.4",
    "@types/uuid": "^10.0.0",
    "pg": "^8.16.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  },
  "keywords": [
    "ai",
    "memory",
    "semantic",
    "agents",
    "langgraph",
    "langchain",
    "embeddings",
    "pgvector"
  ],
  "author": "Joel Friedman",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joelash/engram-ai.git",
    "directory": "packages/engram-ai-js"
  }
}
